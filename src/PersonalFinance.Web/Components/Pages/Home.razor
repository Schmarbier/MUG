@page "/"
@inject ServicioResumen Resumen

<PageTitle>Resumen mensual</PageTitle>

<h1>Resumen — @_mes.ToString("D2")/@_anio</h1>

@if (_resumen is null)
{
    <p>Cargando…</p>
}
else
{
    <BloqueResumen Titulo="Ingresos" Filas="_resumen.Ingresos" PaginaActual="_pagIngresos"
                   HrefPagina="p => Href(pi: p)" />

    <BloqueResumen Titulo="Egresos" Filas="_resumen.Egresos" PaginaActual="_pagEgresos"
                   HrefPagina="p => Href(pe: p)" />
}

@code {
    [SupplyParameterFromQuery] public int? Anio { get; set; }
    [SupplyParameterFromQuery] public int? Mes { get; set; }
    [SupplyParameterFromQuery] public int? PagIngresos { get; set; }
    [SupplyParameterFromQuery] public int? PagEgresos { get; set; }

    private int _anio, _mes, _pagIngresos, _pagEgresos;
    private ResumenMensual? _resumen;

    protected override async Task OnInitializedAsync()
    {
        _anio = Anio ?? DateTime.Today.Year;
        _mes = Mes is >= 1 and <= 12 ? Mes.Value : DateTime.Today.Month;
        _pagIngresos = PagIngresos is > 0 ? PagIngresos.Value : 1;
        _pagEgresos = PagEgresos is > 0 ? PagEgresos.Value : 1;

        _resumen = await Resumen.ObtenerAsync(_anio, _mes);
    }

    private string Href(int? pi = null, int? pe = null)
        => $"/?anio={_anio}&mes={_mes}&pagIngresos={pi ?? _pagIngresos}&pagEgresos={pe ?? _pagEgresos}";
}
