@* Un bloque del resumen (ingresos o egresos) con su tabla y paginación independiente. *@

<section class="bloque">
    <h2>@Titulo</h2>

    @if (Filas.Count == 0)
    {
        <p><em>Sin movimientos este mes.</em></p>
    }
    else
    {
        var pagina = Paginador.Pagina(Filas, PaginaActual);
        var totalPaginas = Paginador.TotalPaginas(Filas.Count);

        <table class="tabla-resumen">
            <thead>
                <tr>
                    <th>Categoría</th>
                    <th>Moneda</th>
                    <th class="num">Total</th>
                    <th class="num">Equivalente ARS</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var f in pagina)
                {
                    <tr>
                        <td>@f.CategoriaTitulo</td>
                        <td>@f.MonedaCodigo</td>
                        <td class="num">@f.Total.ToString("N2")</td>
                        <td class="num">@(f.MonedaCodigo == "ARS" ? "—" : f.EquivalenteArs.ToString("N2"))</td>
                    </tr>
                }
            </tbody>
        </table>

        @if (totalPaginas > 1)
        {
            <nav class="paginacion">
                @for (var p = 1; p <= totalPaginas; p++)
                {
                    var np = p;
                    if (np == PaginaActual)
                    {
                        <span class="pagina actual">@np</span>
                    }
                    else
                    {
                        <a class="pagina" href="@HrefPagina(np)">@np</a>
                    }
                }
            </nav>
        }
    }
</section>

@code {
    [Parameter, EditorRequired] public string Titulo { get; set; } = "";
    [Parameter, EditorRequired] public IReadOnlyList<FilaResumen> Filas { get; set; } = [];
    [Parameter] public int PaginaActual { get; set; } = 1;

    // Construye el href de cada página preservando el estado del otro bloque.
    [Parameter, EditorRequired] public Func<int, string> HrefPagina { get; set; } = _ => "";
}
